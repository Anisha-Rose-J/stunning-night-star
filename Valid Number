class Solution:
    def isNumber(self, s: str) -> bool:
        s = s.strip() # Though LeetCode constraints usually handle this
        num_seen = False
        dot_seen = False
        e_seen = False
        
        for i, char in enumerate(s):
            if char.isdigit():
                num_seen = True
            elif char in "+-":
                if i > 0 and s[i-1].lower() != 'e':
                    return False
            elif char == '.':
                if dot_seen or e_seen:
                    return False
                dot_seen = True
            elif char.lower() == 'e':
                if e_seen or not num_seen:
                    return False
                e_seen = True
                num_seen = False
            else:
                return False
        
        return num_seen
